# Model for the free trial pool
TRIAL_MODEL=gemini/gemini-3-flash-preview

# Google Gemini API key (used by LiteLLM automatically for trial pool)
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Limits
FREE_TRIAL_LIMIT=10
DAILY_LLM_LIMIT=1000

# If using other providers for BYOK users, LiteLLM reads these automatically:
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
