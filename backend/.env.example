# Model for the free trial pool (DeepSeek V3 recommended — no region restrictions)
TRIAL_MODEL=deepseek/deepseek-chat

# Google Gemini API key (used by LiteLLM automatically for trial pool)
# Get yours at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Limits
FREE_TRIAL_LIMIT=10
DAILY_LLM_LIMIT=1000

# DeepSeek API key (used for free trial pool)
# Get yours at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# If using other providers for BYOK users, LiteLLM reads these automatically:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
